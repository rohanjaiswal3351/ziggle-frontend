<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".auth.RegisterActivity"
    android:background="@color/main_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <TextView
            android:id="@+id/text1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:text="What's your first name?"
            android:textSize="40sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/text2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You would be able to change this later."
            android:fontFamily="sans-serif-condensed"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/text1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/addName"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="36dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="20dp"
            android:layout_marginTop="25dp"
            app:cardBackgroundColor="@color/white"
            android:layout_gravity="center"
            app:layout_constraintTop_toBottomOf="@id/text2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <EditText
                android:id="@+id/userName"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Add your first name"
                android:fontFamily="sans-serif-condensed"
                android:background="@color/white"
                android:paddingHorizontal="8dp"/>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This will be shown on your profile."
            android:fontFamily="sans-serif-condensed"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/next1"
            app:layout_constraintBottom_toBottomOf="@id/next1"
            app:layout_constraintStart_toStartOf="parent"
            android:drawablePadding="10dp"
            app:drawableStartCompat="@drawable/ic_baseline_remove_red_eye_24" />

        <ImageView
            android:id="@+id/next1"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_baseline_arrow_circle_right_24"
            android:layout_margin="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout2"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/text4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add your first 2 photos"
            android:fontFamily="sans-serif-condensed"
            android:textSize="40sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/text5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2 photos are better than 1. You can change this later"
            android:fontFamily="sans-serif-condensed"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/text4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:paddingHorizontal="10dp"
            android:paddingVertical="10dp"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="25dp"
            app:layout_constraintTop_toBottomOf="@id/text5"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/setImage"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_light_grey"
                app:cardCornerRadius="15dp"
                android:layout_marginEnd="5dp">

                <ImageView
                    android:id="@+id/image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:id="@+id/show"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_baseline_add_24"/>


            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/setImage1"
                android:layout_width="0dp"
                android:layout_height="140dp"
                android:layout_weight="1"
                app:cardBackgroundColor="@color/bg_light_grey"
                app:cardCornerRadius="15dp"
                android:layout_marginStart="5dp">

                <ImageView
                    android:id="@+id/image1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:id="@+id/show1"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_baseline_add_24"/>


            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <TextView
            android:id="@+id/text6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This will be shown on your profile."
            android:fontFamily="sans-serif-condensed"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/next2"
            app:layout_constraintBottom_toBottomOf="@id/next2"
            app:layout_constraintStart_toStartOf="parent"
            android:drawablePadding="10dp"
            app:drawableStartCompat="@drawable/ic_baseline_remove_red_eye_24" />

        <ImageView
            android:id="@+id/next2"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_baseline_arrow_circle_right_24"
            android:layout_margin="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/textG1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="What's your gender?"
            android:fontFamily="sans-serif-condensed"
            android:textSize="40sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/textG2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pick which best describes you."
            android:fontFamily="sans-serif-condensed"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/textG1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="25dp"
            app:layout_constraintTop_toBottomOf="@id/textG2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/man"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/white"
                android:layout_gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Man"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="@color/black"
                    android:background="@color/white"
                    android:textSize="22sp"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/woman"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/white"
                android:layout_gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Woman"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="@color/black"
                    android:background="@color/white"
                    android:textSize="22sp"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/nonBinary"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/white"
                android:layout_gravity="center"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="Nonbinary"
                    android:fontFamily="sans-serif-condensed"
                    android:textColor="@color/black"
                    android:background="@color/white"
                    android:textSize="22sp"
                    android:gravity="center"/>

            </com.google.android.material.card.MaterialCardView>


        </LinearLayout>


        <TextView
            android:id="@+id/textG3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This will be shown on your profile."
            android:fontFamily="sans-serif-condensed"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            android:drawablePadding="10dp"
            android:layout_marginBottom="20dp"
            app:drawableStartCompat="@drawable/ic_baseline_remove_red_eye_24" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout4"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/text7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="What's your age?"
            android:fontFamily="sans-serif-condensed"
            android:textSize="40sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/text8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You would be able to change this later."
            android:fontFamily="sans-serif-condensed"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/text7"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/addAge"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="36dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="20dp"
            android:layout_marginTop="25dp"
            app:cardBackgroundColor="@color/white"
            android:layout_gravity="center"
            app:layout_constraintTop_toBottomOf="@id/text8"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <EditText
                android:id="@+id/userAge"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:hint="Add your age"
                android:inputType="number"
                android:fontFamily="sans-serif-condensed"
                android:background="@color/white"
                android:paddingHorizontal="8dp"/>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text9"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This will be shown on your profile."
            android:fontFamily="sans-serif-condensed"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/next3"
            app:layout_constraintBottom_toBottomOf="@id/next3"
            app:layout_constraintStart_toStartOf="parent"
            android:drawablePadding="10dp"
            app:drawableStartCompat="@drawable/ic_baseline_remove_red_eye_24" />

        <ImageView
            android:id="@+id/next3"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_baseline_arrow_circle_right_24"
            android:layout_margin="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout5"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <TextView
            android:id="@+id/text10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="What's your country?"
            android:fontFamily="sans-serif-condensed"
            android:textSize="40sp"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <TextView
            android:id="@+id/text11"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="You would be able to change this later."
            android:fontFamily="sans-serif-condensed"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:layout_marginHorizontal="36dp"
            android:layout_marginTop="15dp"
            app:layout_constraintTop_toBottomOf="@id/text10"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/addCountry"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginHorizontal="36dp"
            app:cardCornerRadius="10dp"
            app:cardElevation="20dp"
            android:layout_marginTop="25dp"
            app:cardBackgroundColor="@color/white"
            android:layout_gravity="center"
            app:layout_constraintTop_toBottomOf="@id/text11"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <com.rilixtech.widget.countrycodepicker.CountryCodePicker
                android:id="@+id/ccp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:ccp_defaultNameCode="US"
                app:ccp_showFullName="true"
                app:ccp_hideNameCode="true"
                app:ccp_hidePhoneCode="true"
                android:gravity="center"
                app:ccp_backgroundColor="@color/white" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/text12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This will be shown on your profile."
            android:fontFamily="sans-serif-condensed"
            android:textSize="15sp"
            android:textColor="@color/black"
            android:layout_marginStart="16dp"
            app:layout_constraintTop_toTopOf="@id/next4"
            app:layout_constraintBottom_toBottomOf="@id/next4"
            app:layout_constraintStart_toStartOf="parent"
            android:drawablePadding="10dp"
            app:drawableStartCompat="@drawable/ic_baseline_remove_red_eye_24" />

        <ImageView
            android:id="@+id/next4"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_baseline_arrow_circle_right_24"
            android:layout_margin="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>


</LinearLayout>
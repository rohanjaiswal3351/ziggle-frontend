<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_margin="15dp"
    android:minHeight="70dp">

    <!-- Shown when premium -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/userImage"
        android:layout_width="60dp"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Shown when NOT premium -->
    <ImageView
        android:id="@+id/lockedImage"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_lock"
        android:scaleType="centerInside"
        android:background="@drawable/circle_grey_bg"
        android:padding="14dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Premium text block -->
    <LinearLayout
        android:id="@+id/premiumTextBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toEndOf="@id/userImage"
        app:layout_constraintEnd_toStartOf="@id/no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/userName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ziggle"
            android:fontFamily="sans-serif-condensed"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/text1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sent you a friend"
            android:fontFamily="sans-serif-condensed" />

        <TextView
            android:id="@+id/text2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="request"
            android:fontFamily="sans-serif-condensed" />

    </LinearLayout>

    <!-- Locked text block -->
    <LinearLayout
        android:id="@+id/lockedTextBlock"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:visibility="gone"
        app:layout_constraintStart_toEndOf="@id/lockedImage"
        app:layout_constraintEnd_toStartOf="@id/no"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/lockedName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Someone"
            android:fontFamily="sans-serif-condensed"
            android:textColor="@color/black"
            android:textStyle="bold"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/lockedSubText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="sent you a friend request"
            android:fontFamily="sans-serif-condensed"
            android:textColor="@color/black" />

    </LinearLayout>

    <ImageView
        android:id="@+id/no"
        android:layout_width="15dp"
        android:layout_height="15dp"
        android:src="@drawable/clear"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toStartOf="@id/yes"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="35dp"/>

    <ImageView
        android:id="@+id/yes"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/check"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginEnd="10dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
